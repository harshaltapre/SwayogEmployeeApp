{
    "name": "dashboard-swayog-backend",
    "version": "1.0.0",
    "description": "Backend server for Dashboard Swayog (TypeScript + Prisma)",
    "type": "module",
    "main": "dist/server.js",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc -p tsconfig.json",
        "bundle:vercel": "esbuild src/app.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/vercel-app.cjs --packages=external --minify --sourcemap=external",
        "start": "node dist/server.js",
        "typecheck": "tsc --noEmit",
        "foxess:test": "tsx ./scripts/test-foxess.ts",
        "prisma:generate": "dotenv -o -e .env -- prisma generate",
        "prisma:migrate": "dotenv -o -e .env -- prisma migrate dev",
            "prisma:backfill": "dotenv -o -e .env -- tsx prisma/scripts/backfill-task-assignees.ts",
        "prisma:migrate:deploy": "dotenv -o -e .env -- prisma migrate deploy",
        "prisma:push": "dotenv -o -e .env -- prisma db push",
        "prisma:seed": "tsx prisma/seed.ts",
        "seed": "dotenv -o -e .env -- tsx prisma/seed.ts",
        "prisma:studio": "dotenv -o -e .env -- prisma studio"
    },
    "keywords": [
        "express",
        "prisma",
        "postgresql",
        "typescript"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@neondatabase/serverless": "^1.1.0",
        "@prisma/adapter-neon": "^6.19.3",
        "@prisma/client": "^6.19.3",
        "@types/multer": "^2.1.0",
        "@types/ws": "^8.18.1",
        "axios": "^1.16.1",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.21.2",
        "helmet": "^8.2.0",
        "jsonwebtoken": "^9.0.2",
        "multer": "^2.1.1",
        "nodemailer": "^6.9.4",
        "redis": "^4.7.0",
        "sharp": "^0.32.1",
        "exif-parser": "^0.1.12",
        "swayog-energy": "file:..",
        "ws": "^8.20.1",
        "zod": "^3.24.2"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.9",
        "@types/node": "^22.13.14",
        "@types/nodemailer": "^8.0.0",
        "dotenv-cli": "^7.4.4",
        "esbuild": "^0.25.0",
        "prisma": "^6.19.3",
        "tsx": "^4.19.3",
        "typescript": "^5.8.2"
    }
}
