{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "src/**/test-*.ts",
    "src/**/test_*.ts",
    "src/**/scratch*.ts",
    "src/**/debug-*.ts",
    "src/**/scratch-*.ts",
    "src/**/__tests__/**",
    "src/**/test-helpers/**"
  ]
}
