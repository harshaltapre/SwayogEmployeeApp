DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=dashboard_swayog
PORT=4000
NODE_ENV=production

# Neon runtime connection string used by the app.
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require&channel_binding=require

# Neon direct connection string used by Prisma migrations.
DIRECT_URL=postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require&channel_binding=require

JWT_ACCESS_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_REFRESH_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
CORS_ORIGIN=https://your-frontend-domain.vercel.app
TRUST_PROXY=true
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false
REDIS_KEY_PREFIX=swayog
AUTH_LOGIN_RATE_LIMIT_MAX=20
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=900000
AUTH_REGISTER_RATE_LIMIT_MAX=10
AUTH_REGISTER_RATE_LIMIT_WINDOW_MS=900000
AUTH_REFRESH_RATE_LIMIT_MAX=30
AUTH_REFRESH_RATE_LIMIT_WINDOW_MS=300000
AUTH_LOGOUT_RATE_LIMIT_MAX=60
AUTH_LOGOUT_RATE_LIMIT_WINDOW_MS=300000
AUTH_ME_RATE_LIMIT_MAX=120
AUTH_ME_RATE_LIMIT_WINDOW_MS=60000
AUTH_LOCKOUT_ENABLED=true
AUTH_LOCKOUT_MAX_ATTEMPTS=5
AUTH_LOCKOUT_DURATION_MS=900000
SEED_SUPER_ADMIN_NAME=Super Admin
SEED_SUPER_ADMIN_EMAIL=superadmin@example.com
SEED_SUPER_ADMIN_PASSWORD=ReplaceWithStrongPassword

# Waaree API Settings
WAAREE_API_BASE_URL=https://digital.waaree.com
WAAREE_API_TOKEN=your-waaree-api-token
WAAREE_API_SECRET=your-waaree-api-secret-key
WAAREE_PLANT_ID=your-waaree-plant-id-number

# Waaree / Solax Inverter API
WAAREE_SOLAX_TOKEN_ID="your-solax-token-id-here"
WAAREE_SOLAX_INVERTER_SN="your-inverter-serial-number-here"