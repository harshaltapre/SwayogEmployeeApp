# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# Local dev: points at Vite dev server; /api is proxied to the backend (vite.config.ts).
VITE_API_BASE_URL=http://127.0.0.1:3000

# Optional – only if auth API is on another origin
# VITE_AUTH_API_BASE_URL=http://127.0.0.1:3000

# Vercel: leave VITE_* unset so the browser uses the same origin for /api/v1 (serverless API).

# ─── Backend (copy to backend/.env for local API + Prisma) ───────────────────
# Neon – paste URI from Neon → Connection string (reset password if it was ever leaked)
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# DIRECT_URL=postgresql://USER:PASSWORD@ep-xxxxx.region.aws.neon.tech/neondb?sslmode=require

# DATABASE_URL=postgresql://postgres:password@localhost:5432/dashboard_swayog?schema=public
# NODE_ENV=production
# JWT_ACCESS_SECRET=...          # min 32 characters
# JWT_REFRESH_SECRET=...         # min 32 characters, different from access
# CORS_ORIGIN=https://your-app.vercel.app
# REDIS_ENABLED=false            # on Vercel unless you use Redis

# Super admin (used when running: npm run prisma:seed --prefix backend)
# SEED_SUPER_ADMIN_EMAIL=you@example.com
# SEED_SUPER_ADMIN_PASSWORD=YourSecurePassword

# After DB exists: npm run prisma:migrate:deploy --prefix backend
# Then seed:       npm run prisma:seed --prefix backend
#
# Production login (after seed): use SEED_SUPER_ADMIN_EMAIL / SEED_SUPER_ADMIN_PASSWORD from backend/.env
# Vercel: set DATABASE_URL, DIRECT_URL, JWT_ACCESS_SECRET, JWT_REFRESH_SECRET, CORS_ORIGIN=https://swayog-dashboard.vercel.app
